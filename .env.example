# Copy this file to .env and add your Mistral API key
MISTRAL_API_KEY=your_mistral_api_key_here

# Agent loop settings
MAX_ITERATIONS=20
MAX_TOKENS_BUDGET=0

# LLM provider settings
LLM_PROVIDER=mistral
LLM_MODEL=
LLM_TEMPERATURE=0.7

# Logging configuration
LOG_LEVEL=info
LOG_ENABLED=true
LOG_DESTINATION=stdout
LOG_NAME=agentloop
LOG_TIMESTAMP=true